{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kiebitz",
  $10.5.0",
  "identifier": "de.torim.kiebitz",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kiebitz",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 660,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "binaries/stockfish.exe",
      "resources/stockfish/NOTICE.txt",
      "resources/stockfish/COPYING.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2N0I0OUI5MEUyRUE0NTIKUldSU3BDNE91VWw3MXM3QVdnVFRtNTVOZDgralo3SklaNXVicEMraUpTNzA5eDJMS0Ixd213bXIK",
      "endpoints": [
        "https://github.com/Torim98/Kiebitz/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
